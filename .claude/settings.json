{
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "MultiEdit",
      "Bash(git *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(yarn *)",
      "Bash(pnpm *)",
      "Bash(bun *)",
      "Bash(pip *)",
      "Bash(python *)",
      "Bash(node *)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(diff *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(go *)",
      "Bash(make *)",
      "Bash(gofmt *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "command": "if [[ \"$FILEPATH\" == *.go ]]; then gofmt -w \"$FILEPATH\" 2>/dev/null || true; fi",
        "timeout": 15000
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "command": "echo 'Remember: run make test before ending this session.'"
      }
    ]
  }
}
