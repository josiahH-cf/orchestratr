{
  "permissions": {
    "defaultMode": "bypassPermissions"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "command": "gofmt -w \"$FILEPATH\" 2>/dev/null; true"
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "command": "golangci-lint run --fix ./... 2>/dev/null; true"
      }
    ]
  }
}
